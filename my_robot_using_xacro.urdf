<?xml version="1.0"?>
<robot name="my_robot_using_xacro" xmlns:xacro="http://www.ros.org/wiki/xacro">

<xacro:property name="base_width" value="0.31" />
<xacro:property name="base_length" value="0.6" />
<xacro:property name="base_height" value="0.2" />

  <xacro:macro name="box_inertia" params="m w h d">
    <inertial>
      <mass value="${m}" />
      <inertia ixx="${(m*(h*h+d*d))/12}" ixy="0" ixz="0" iyy="${(m*(w*w+d*d))/12}" iyz="0" izz="${(m*(w*w+h*h))/12}" />
    </inertial>
  </xacro:macro>

<link name="base_link">
  <visual>
    <origin rpy="0 0 0" xyz="${base_length/2} 0 0"/>
    <geometry>
      <box size="${base_length} ${base_width} ${base_height}"/>
    </geometry>
  </visual>

  <collision>
     <origin rpy="0 0 0" xyz="${base_length/2} 0 0"/>
    <origin rpy="0 0 0" xyz="${base_length/2} 0 0"/>
    <geometry>
      <box size="${base_length} ${base_width} ${base_height}"/>
    </geometry>
  </collision>
  <xacro:box_inertia m="1" w="${base_width}" h="${base_height}" d="${base_length}"/>
</link>

<link name="right_leg">
  <visual>
    <origin rpy="0 1.57075 0" xyz="0 0 -0.3"/>
    <geometry>
      <box size="0.6 0.1 0.2"/>
    </geometry>
  </visual>

  <collision>
    <origin rpy="0 1.57075 0" xyz="0 0 -0.3"/>
    <geometry>
      <box size="0.6 0.1 0.2"/>
    </geometry>
  </collision>
  <xacro:box_inertia m="1" w="0.1" h="0.2" d="0.6"/>
</link>

<joint name="base_to_right_leg" type="fixed">
  <parent link="base_link"/>
  <child link="right_leg"/>
  <origin xyz="0 -0.22 0.25"/>
</joint>

<link name="right_base">
  <visual>
    <origin rpy="0 0 0" xyz="0 0 -0.6"/>
    <geometry>
      <box size="0.4 0.1 0.1"/>
    </geometry>
  </visual>

  <collision>
    <origin rpy="0 0 0" xyz="0 0 -0.6"/>
    <geometry>
      <box size="0.4 0.1 0.1"/>
    </geometry>
  </collision>
  <xacro:box_inertia m="1" w="0.1" h="0.1" d="0.4"/>    

</link>

<joint name="right_base_joint" type="fixed">
  <parent link="right_leg"/>
  <child link="right_base"/>
  <origin xyz="0 0 -0.6"/>
</joint>

<link name="right_front_wheel">
  <visual>
    <origin rpy="1.57075 0 0" xyz="0 0 0"/>
    <geometry>
      <cylinder length="0.1" radius="0.035"/>
    </geometry>
  </visual>

  <collision>
    <origin rpy="1.57075 0 0" xyz="0 0 0"/>
    <geometry>
      <cylinder length="0.1" radius="0.035"/>
    </geometry>
  </collision>      
    <inertial>
        <mass value="0.1" />
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
    </inertial>
</link>

<joint name="right_front_wheel_joint" type="fixed">
  <parent link="right_base"/>
  <child link="right_front_wheel"/>     
</joint>

<link name="right_back_wheel">
  <visual>
    <origin rpy="1.57075 0 0" xyz="0 0 0"/>
    <geometry>
      <cylinder length="0.1" radius="0.035"/>
    </geometry>
  </visual>

  <collision>
    <origin rpy="1.57075 0 0" xyz="0 0 0"/>
    <geometry>
      <cylinder length="0.1" radius="0.035"/>
    </geometry>
  </collision>      
    <inertial>
        <mass value="0.1" />
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
    </inertial>
</link> 

<joint name="right_back_wheel_joint" type="fixed">
  <parent link="right_base"/>
  <child link="right_back_wheel"/>
</joint>

<link name="left_leg">
  <visual>
    <origin rpy="0 1.57075 0" xyz="0 0 -0.3"/>
    <geometry>
      <box size="0.6 0.1 0.2"/>
    </geometry>
  </visual>

  <collision>
    <origin rpy="0 1.57075 0" xyz="0 0 -0.3"/>
    <geometry>
      <box size="0.6 0.1 0.2"/>
    </geometry>
  </collision>
  <xacro:box_inertia m="1" w="0.1" h="0.2" d="0.6"/>
</link> 

<joint name="base_to_left_leg" type="fixed">
  <parent link="base_link"/>
  <child link="left_leg"/>
  <origin xyz="0 0.22 0.25"/>   
</joint>

<link name="left_base">
  <visual>
    <origin rpy="0 0 0" xyz="0 0 -0.6"/>
    <geometry>
      <box size="0.4 0.1 0.1"/>
    </geometry>
  </visual>

  <collision>
    <origin rpy="0 0 0" xyz="0 0 -0.6"/>
    <geometry>
      <box size="0.4 0.1 0.1"/>
    </geometry>
  </collision>
  <xacro:box_inertia m="1" w="0.1" h="0.1" d="0.4"/>    
</link>

<joint name="left_base_joint" type="fixed">
  <parent link="left_leg"/>
  <child link="left_base"/>
  <origin xyz="0 0 -0.6"/>
</joint>

<link name="left_front_wheel">
  <visual>
    <origin rpy="1.57075 0 0" xyz="0 0 0"/>
    <geometry>
      <cylinder length="0.1" radius="0.035"/>
    </geometry>
  </visual>

  <collision>
    <origin rpy="1.57075 0 0" xyz="0 0 0"/>
    <geometry>
      <cylinder length="0.1" radius="0.035"/>
    </geometry>
  </collision>      
    <inertial>
        <mass value="0.1" />
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
    </inertial>
</link>

<joint name="left_front_wheel_joint" type="fixed">
  <parent link="left_base"/>
  <child link="left_front_wheel"/>
</joint>

<link name="left_back_wheel">
  <visual>
    <origin rpy="1.57075 0 0" xyz="0 0 0"/>
    <geometry>
      <cylinder length="0.1" radius="0.035"/>
    </geometry>
  </visual>

  <collision>
    <origin rpy="1.57075 0 0" xyz="0 0 0"/>
    <geometry>
      <cylinder length="0.1" radius="0.035"/>
    </geometry>
  </collision>      
    <inertial>
        <mass value="0.1" />
        <inertia ixx="0.0001" ixy="0" ixz="0" iyy="0.0001" iyz="0" izz="0.0001" />
    </inertial>
</link> 

<joint name="left_back_wheel_joint" type="fixed">
  <parent link="left_base"/>
  <child link="left_back_wheel"/>
</joint>

<link name="head">
  <visual>
    <origin rpy="0 0 0" xyz="0.6 0 0.1"/>
    <geometry>
      <box size="0.2 0.2 0.2"/>
    </geometry>
  </visual>

  <collision>
    <origin rpy="0 0 0" xyz="0.6 0 0.1"/>
    <geometry>
      <box size="0.2 0.2 0.2"/>
    </geometry>
  </collision>
  <xacro:box_inertia m="1" w="0.2" h="0.2" d="0.2"/>
</link>

<joint name="base_to_head" type="fixed">
  <parent link="base_link"/>
  <child link="head"/>
  <origin xyz="0.6 0 0.1"/>
</joint>

<link name="left_arm">
  <visual>
    <origin rpy="0 0 0" xyz="0.3 0.15 0"/>
    <geometry>
      <box size="0.3 0.1 0.1"/>
    </geometry>
  </visual>

  <collision>
    <origin rpy="0 0 0" xyz="0.3 0.15 0"/>
    <geometry>
      <box size="0.3 0.1 0.1"/>
    </geometry>
  </collision>
  <xacro:box_inertia m="1" w="0.1" h="0.1" d="0.3"/>
</link> 

<joint name="base_to_left_arm" type="fixed">
  <parent link="base_link"/>
  <child link="left_arm"/>
  <origin xyz="0.3 0.15 0"/>    
</joint>

<link name="right_arm">
  <visual>
    <origin rpy="0 0 0" xyz="0.3 -0.15 0"/>
    <geometry>
      <box size="0.3 0.1 0.1"/>
    </geometry>
  </visual>

  <collision>
    <origin rpy="0 0 0" xyz="0.3 -0.15 0"/>
    <geometry>
      <box size="0.3 0.1 0.1"/>
    </geometry>
  </collision>
  <xacro:box_inertia m="1" w="0.1" h="0.1" d="0.3"/>
</link>

<joint name="base_to_right_arm" type="fixed">
  <parent link="base_link"/>
  <child link="right_arm"/>
  <origin xyz="0.3 -0.15 0"/>    
</joint>

</robot>